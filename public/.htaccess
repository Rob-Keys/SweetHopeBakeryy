RewriteEngine On

# 1. Redirect non-www to www
RewriteCond %{HTTP_HOST} ^sweethopebakeryy\.com$ [NC]
RewriteRule ^(.*)$ https://www.sweethopebakeryy.com/$1 [R=301,L]

# 2. Let sitemap.xml load directly
RewriteCond %{REQUEST_URI} ^/sitemap\.xml$ [NC]
RewriteRule ^sitemap\.xml$ sitemap.xml [L]

# 3. Allow access to real files or folders
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# 4. Route everything else to index.php
RewriteRule ^ index.php [L]
